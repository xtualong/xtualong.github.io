# PocketBase Docker Configuration

# Docker image version
VERSION=latest
CONTAINER_NAME=pocketbase

# Network
HOST_IP=0.0.0.0
WEB_HTTP_PORT=8090

# Resource limits (0 = unlimited)
CPUS=0
MEMORY_LIMIT=0MB

# Host path for PocketBase data, hooks, and migrations
# Ensure these directories exist on the host before starting:
#   ${APP_PATH}/pb_data        - Database, logs, file storage
#   ${APP_PATH}/pb_hooks       - JS extension scripts (.js/.ts)
#   ${APP_PATH}/pb_migrations  - Database migration files
APP_PATH=/www/dk_project/dk_app/pocketbase/pocketbase

# Admin credentials (change before first run!)
PB_ADMIN_EMAIL=admin@xtualong.cn
PB_ADMIN_PASSWORD=改成你的密码
